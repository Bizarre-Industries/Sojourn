// Sojourn — Debug xcconfig
//
// Local, unsigned development build. Set DEVELOPMENT_TEAM via a per-user
// Local.xcconfig (gitignored) or with `xcodebuild DEVELOPMENT_TEAM=XXXX`.

#include? "Local.xcconfig"

SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG SOJOURN_DEBUG
SWIFT_OPTIMIZATION_LEVEL = -Onone
GCC_OPTIMIZATION_LEVEL = 0
ONLY_ACTIVE_ARCH = YES
ENABLE_TESTABILITY = YES
ENABLE_PREVIEWS = YES
MTL_ENABLE_DEBUG_INFO = INCLUDE_SOURCE
CODE_SIGN_STYLE = Automatic

SWIFT_STRICT_CONCURRENCY = complete
SWIFT_UPCOMING_FEATURE_EXISTENTIAL_ANY = YES
